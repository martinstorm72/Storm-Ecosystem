# ============================================================
#  .gitignore — keeps secrets OUT of GitHub
# ============================================================

# LOCAL SECRETS — never commit these
config.js
.env
.env.local
.env.*.local

# OS / editor junk
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/
.idea/

# Logs
*.log
npm-debug.log*

# Node (if you ever add a build step)
node_modules/
dist/
